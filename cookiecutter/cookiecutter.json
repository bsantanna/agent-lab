{
    "project_name": "My Agent App",
    "project_slug": "{{ cookiecutter.project_name.lower().replace('_', '-').replace(' ', '-') }}",
    "package_name": "{{ cookiecutter.project_slug.replace('-', '_') }}",
    "description": "An Agent-Lab powered application",
    "author_name": "Your Name",
    "author_email": "you@example.com",
    "github_repository": "your-org/{{ cookiecutter.project_slug }}",
    "agent_lab_version": "1.15.0",
    "include_docker": true,
    "include_github_actions": true,
    "include_testcontainers": true,
    "include_claude_plugin": true,
    "include_release_pipeline": true,
    "include_aks_gitops": false,
    "auth_enabled": false,
    "_copy_without_render": [
        "{{cookiecutter.package_name}}/agents/react_agent/default_execution_system_prompt.txt",
        ".github/workflows/release.yml",
        ".github/workflows/docker-image.yml"
    ]
}
